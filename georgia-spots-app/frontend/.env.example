# Optional: enables the "Sign in with Google" button on the login/register pages.
# Leave blank to disable it (email/password login still works fine without it).
# Create a Web application OAuth Client ID at https://console.cloud.google.com/apis/credentials
# and add http://localhost:5173 as an authorized JavaScript origin.
# Must match the GOOGLE_CLIENT_ID you set in backend/.env.
VITE_GOOGLE_CLIENT_ID=

# Production only. Your deployed backend's full URL, e.g. https://api.vanlife.ge
# (no trailing slash). Leave blank for local development - Vite's dev server proxies
# /api requests to localhost:4000 automatically (see vite.config.ts).
VITE_API_URL=
