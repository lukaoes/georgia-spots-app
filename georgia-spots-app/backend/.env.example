PORT=4000
JWT_SECRET=change-this-to-a-long-random-string

# Optional: enables "Sign in with Google". Leave blank to disable it.
# Create a Web application OAuth Client ID at https://console.cloud.google.com/apis/credentials
# and add http://localhost:5173 as an authorized JavaScript origin.
GOOGLE_CLIENT_ID=

# Production only. Path to the SQLite database file - point this at your host's persistent
# volume (e.g. /data/data.sqlite on Northflank) so the database survives redeploys.
# Leave blank for local development (defaults to a file next to the project).
DB_PATH=

# Production only. Comma-separated list of your real frontend URL(s), e.g.
# https://vanlife.ge,https://www.vanlife.ge
# Leave blank for local development (CORS stays open, which is fine on localhost).
FRONTEND_ORIGIN=

# Optional but recommended for production: stores uploaded photos on Cloudflare R2 instead of
# local disk (R2's free tier is 10GB, ~50,000 photos at this app's compression settings - local
# disk on most free hosts is much smaller and isn't guaranteed to survive a redeploy).
# Leave all four blank to keep using local disk (fine for local development).
# Setup: create a bucket at https://dash.cloudflare.com -> R2, create an API token scoped to
# that bucket, and enable public access (or a custom domain) on the bucket for R2_PUBLIC_URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional. Text stamped in the bottom-right corner of place/review photos (not avatars).
# Defaults to "vanlife.ge" if left blank.
WATERMARK_TEXT=
