# Copy this file to ".env" in the same folder as docker-compose.yml on your CasaOS server,
# and fill in the real values. This file (the real ".env", not this example) should NEVER be
# committed to GitHub - it holds real secrets.

JWT_SECRET=paste-a-long-random-string-here

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# From Cloudflare Zero Trust -> Networks -> Tunnels -> your tunnel -> the token shown in the
# "docker run" command it gives you (just the long token string, not the whole command).
CLOUDFLARE_TUNNEL_TOKEN=
